{
  "id": "caos",
  "faccion": {
    "nombre": "Caos",
    "estilo_juego": "Facción de oleadas y presión constante, diseñada para saturar al enemigo con números y nunca dejar de avanzar. Sus unidades de Línea son las más baratas del juego: caen con facilidad pero reaparecen turno tras turno desde los puestos de mando. El cuerpo a cuerpo y el control del espacio son su arma principal. Ideal para jugadores que disfrutan de la presión sostenida, el desgaste progresivo y el caos controlado.",
    "seleccion_habilidades": "multiple",
    "habilidades_faccion": [
      {
        "id": "oleada-eterna",
        "nombre": "Oleada eterna",
        "coste": 8,
        "descripcion_escaramuza": "Cuando una unidad de Línea es eliminada, al inicio de la siguiente Fase de Iniciativa regresa desde cualquier puesto de mando vacío con todas sus Vidas.",
        "descripcion_escuadra": "Cuando una escuadra de Línea es eliminada, al inicio de la siguiente Fase de Iniciativa regresa desde cualquier puesto de mando vacío con todas sus Vidas."
      },
      {
        "id": "instinto-de-enjambre",
        "nombre": "Instinto de horda",
        "coste": 4,
        "descripcion_escaramuza": "Las unidades a 3\" o menos de otra unidad aliada repiten los dados de ataque cuerpo a cuerpo fallidos.",
        "descripcion_escuadra": "Las escuadras a 3\" o menos de otra escuadra aliada repiten los dados de ataque cuerpo a cuerpo fallidos."
      },
      {
        "id": "carga-salvaje",
        "nombre": "Carga salvaje",
        "coste": 7,
        "descripcion_escaramuza": "Cuando una unidad de esta facción realiza una carga exitosa, suma +1 de Daño en los ataques cuerpo a cuerpo de esa activación.",
        "descripcion_escuadra": "Cuando una escuadra de esta facción realiza una carga exitosa, suma +1 de Daño en los ataques cuerpo a cuerpo de esa activación."
      },
      {
        "id": "propagacion-de-veneno",
        "nombre": "Propagación de veneno",
        "coste": 6,
        "descripcion_escaramuza": "Las unidades enemigas que pierdan al menos 1 Vida en CaC contra una unidad de Caos deben realizar una tirada después del combate. Con 4+, esa unidad sufre 1 punto de daño extra.",
        "descripcion_escuadra": "Las escuadras enemigas que pierdan al menos 1 Vida en CaC contra una escuadra de Caos deben realizar una tirada después del combate. Con 4+, esa escuadra sufre 1 punto de daño extra."
      },
      {
        "id": "regeneracion",
        "nombre": "Regeneración",
        "coste": 6,
        "descripcion_escaramuza": "Al inicio de cada Fase de Iniciativa, una unidad de Caos a tu elección recupera 1 Vida, hasta su máximo. Solo puede usarse sobre unidades que no hayan sido eliminadas ese turno.",
        "descripcion_escuadra": "Al inicio de cada Fase de Iniciativa, una escuadra de Caos a tu elección recupera 1D3 Vidas, hasta su máximo. Solo puede usarse sobre escuadras que no hayan sido eliminadas ese turno."
      }
    ]
  },
