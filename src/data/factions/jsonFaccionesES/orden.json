{
  "id": "orden",
  "faccion": {
    "nombre": "Orden",
    "estilo_juego": "Facción disciplinada y metódica centrada en el control del territorio y el fuego sostenido. Sus unidades rinden mejor cuando se mantienen en posición y coordinación táctica. Sacrifica movilidad a cambio de potencia y precisión. Ideal para jugadores que disfrutan de planificar cada turno, establecer líneas defensivas y castigar al enemigo con unidades equilibradas.",
    "seleccion_habilidades": "individual",
    "habilidades_faccion": [
      {
        "id": "cadena-de-mando",
        "nombre": "Cadena de mando",
        "descripcion_escaramuza": "Una vez por turno, cuando una unidad ORDEN se active, otra unidad ORDEN a 6\" o menos puede activarse inmediatamente después sin esperar el turno del rival.",
        "descripcion_escuadra": "Una vez por turno, cuando una unidad ORDEN se active, otra unidad ORDEN a 6\" o menos puede activarse inmediatamente después sin esperar el turno del rival.",
        "frase": "El orden es el origen de la justicia"
      },
      {
        "id": "fortificacion",
        "nombre": "Fortificación",
        "descripcion_escaramuza": "Los puestos de mando bajo tu control cuentan como en cobertura.",
        "descripcion_escuadra": "Los puestos de mando bajo tu control cuentan como en cobertura.",
        "frase": "Donde plantamos bandera, no se da un paso atrás."
      },
      {
        "id": "doctrina",
        "nombre": "Doctrina",
        "descripcion_escaramuza": "Antes de comenzar la partida, elige un tipo de unidad enemigo: Línea, Élite, Vehículo, Monstruo, Héroe o Titán. Tus unidades pueden repetir todos los fallos al atacar a unidades de ese tipo hasta el final de la partida.",
        "descripcion_escuadra": "Antes de comenzar la partida, elige un tipo de unidad enemigo: Línea, Élite, Vehículo, Monstruo, Héroe o Titán. Tus unidades pueden repetir todos los fallos al atacar a unidades de ese tipo hasta el final de la partida.",
        "frase": "Conoce a tu enemigo antes de levantar el arma."
      }
    ]
  },
