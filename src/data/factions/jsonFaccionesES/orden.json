{
  "id": "orden",
  "faccion": {
    "nombre": "Orden",
    "estilo_juego": "Facción disciplinada y metódica centrada en el control del territorio y el fuego sostenido. Sus unidades rinden mejor cuando se mantienen en posición y coordinación táctica. Sacrifica movilidad a cambio de potencia y precisión. Ideal para jugadores que disfrutan de planificar cada turno, establecer líneas defensivas y castigar al enemigo con unidades equilibradas.",
    "seleccion_habilidades": "multiple",
    "habilidades_faccion": [
      {
        "id": "atrincheramiento",
        "nombre": "Atrincheramiento",
        "coste": 8,
        "descripcion_escaramuza": "Una unidad en cobertura, durante su activación obtiene +1 dado más de ataques de Disparo hasta el final de esa activación.",
        "descripcion_escuadra": "Una escuadra en cobertura, durante su activación obtiene +1 dado más de ataques de Disparo hasta el final de esa activación."
      },
      {
        "id": "fuego-coordinado",
        "nombre": "Fuego coordinado",
        "coste": 5,
        "descripcion_escaramuza": "Si una unidad aliada dispara al mismo objetivo en el mismo turno, la segunda y siguientes aplican -1 a su valor de Precisión (mejora la tirada para impactar) en el turno.",
        "descripcion_escuadra": "Si una escuadra o unidad aliada dispara al mismo objetivo en el mismo turno, la segunda y siguientes aplican -1 a su valor de Precisión (mejora la tirada para impactar) en el turno."
      },
      {
        "id": "repliegue-tactico",
        "nombre": "Repliegue táctico",
        "coste": 4,
        "descripcion_escaramuza": "Una vez por turno, una unidad puede retirarse de un combate cuerpo a cuerpo sin realizar chequeo de retirada.",
        "descripcion_escuadra": "Una vez por turno, una escuadra puede retirarse de un combate cuerpo a cuerpo sin realizar chequeo de retirada."
      },
      {
        "id": "artilleria-de-apoyo",
        "nombre": "Artillería de apoyo",
        "coste": 7,
        "descripcion_escaramuza": "Una vez por turno, en lugar de activar una unidad, puedes realizar un bombardeo sobre cualquier punto del tablero a más de 6\" de tus propias unidades. Todas las unidades en 3\" de ese punto sufren 1 impacto automático con Daño 1, sin salvación.",
        "descripcion_escuadra": "Una vez por turno, en lugar de activar una escuadra o unidad, puedes realizar un bombardeo sobre cualquier punto del tablero a más de 6\" de tus propias unidades. Todas las escuadras o unidades en 3\" de ese punto sufren 1 impacto automático con Daño 1, sin salvación."
      },
      {
        "id": "formacion-de-asalto",
        "nombre": "Formación de asalto",
        "coste": 5,
        "descripcion_escaramuza": "Cuando una unidad declara una carga, puede repetir uno de los dos dados del 2D6 de carga. El resultado anterior queda anulado.",
        "descripcion_escuadra": "Cuando una escuadra declara una carga, puede repetir uno de los dos dados del 2D6 de carga. El resultado anterior queda anulado."
      },
      {
        "id": "contraofensiva",
        "nombre": "Contraofensiva",
        "coste": 4,
        "descripcion_escaramuza": "Cuando una unidad del Orden realiza un contraataque en combate cuerpo a cuerpo, gana +1 dado de CaC.",
        "descripcion_escuadra": "Cuando una escuadra del Orden realiza un contraataque en combate cuerpo a cuerpo, gana +1 dado de CaC."
      }
    ]
  },
