{
  "id": "legado",
  "faccion": {
    "nombre": "Legado",
    "estilo_juego": "Facción de control y posicionamiento que apuesta por la calidad sobre la cantidad. Sus unidades son las más resistentes del juego pero dispone de menos. Usa portales para teleportarse donde el rival no espera, revive a sus caídos con probabilidad y contraataca incluso al morir. El control del tablero es suyo si el jugador es paciente. Ideal para jugadores estratégicos que disfrutan de la microgestión, el posicionamiento y hacer que cada unidad cuente.",
    "seleccion_habilidades": "individual",
    "habilidades_faccion": [
      {
        "id": "el-ultimo-aliento",
        "nombre": "El Último Aliento",
        "descripcion_escaramuza": "Cuando una unidad LEGADO es destruida, realiza un último ataque a distancia o a cuerpo a cuerpo tenga o no acciones.",
        "descripcion_escuadra": "Cuando una unidad LEGADO es destruida, realiza un último ataque a distancia o a cuerpo a cuerpo tenga o no acciones.",
        "frase": "Nada muere fácil."
      },
      {
        "id": "el-vacio-llama",
        "nombre": "El Vacío llama",
        "descripcion_escaramuza": "Una vez por turno, durante la Fase de Iniciativa y antes de cualquier activación, LEGADO puede intercambiar las posiciones de dos unidades aliadas cualesquiera en el campo, siempre que ninguna esté trabada.",
        "descripcion_escuadra": "Una vez por turno, durante la Fase de Iniciativa y antes de cualquier activación, LEGADO puede intercambiar las posiciones de dos unidades aliadas cualesquiera en el campo, siempre que ninguna esté trabada.",
        "frase": "El rival no puede planificar nada contra ti."
      },
      {
        "id": "ecos-del-pasado",
        "nombre": "Ecos del pasado",
        "descripcion_escaramuza": "Cuando una unidad LEGADO sea destruida, lanza 1D6. Con 5 o 6, en lugar de retirarla del juego, vuelve a Reserva. Para volver a desplegarla en el campo, deberás gastar Fichas de Mando según su tipo: 1 ficha para Línea, Élite o Héroe; 2 para Monstruo o Vehículo; 3 para Titán.",
        "descripcion_escuadra": "Cuando una unidad LEGADO sea destruida, lanza 1D6. Con 5 o 6, en lugar de retirarla del juego, vuelve a Reserva. Para volver a desplegarla en el campo, deberás gastar Fichas de Mando según su tipo: 1 ficha para Línea, Élite o Héroe; 2 para Monstruo o Vehículo; 3 para Titán.",
        "frase": "Siempre se tiene una segunda oportunidad."
      },
      {
        "id": "mando-reservado",
        "nombre": "Mando Reservado",
        "descripcion_escaramuza": "Al inicio de cada Fase de Iniciativa, este jugador gana 1 Ficha de Mando adicional, sumada a las generadas por puestos de mando. El máximo de Fichas acumuladas sigue siendo 5.",
        "descripcion_escuadra": "Al inicio de cada Fase de Iniciativa, este jugador gana 1 Ficha de Mando adicional, sumada a las generadas por puestos de mando. El máximo de Fichas acumuladas sigue siendo 5.",
        "frase": "La mejor batalla es la que se gana con paciencia."
      }
    ]
  },
