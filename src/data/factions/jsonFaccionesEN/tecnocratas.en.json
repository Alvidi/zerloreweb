{
  "faccion": {
    "nombre": "Technocrats",
    "estilo_juego": "A tactical and flexible faction, specialised in constant repositioning and coordinated support between units. It does not seek frontal confrontation, preferring to wear down the enemy through technical superiority and battlefield control.",
    "seleccion_habilidades": "multiple",
    "habilidades_faccion": [
      {
        "id": "retirada-inteligente",
        "habilidades_faccion1": "Smart withdrawal",
        "coste": 8,
        "descripcion_escaramuza": "Units of this faction can retreat without needing to take a retreat test.",
        "descripcion_escuadra": "Units of this faction can retreat without needing to take a retreat test."
      },
      {
        "id": "apoyo-de-artefacto",
        "habilidades_faccion2": "Artifact support",
        "coste": 10,
        "descripcion_escaramuza": "Each Line or Elite unit in the faction may attach 1 miniature with the \"Artifact Support\" specialty, even if the squad is already at its maximum size. The artifact is added above the squad limit. In Skirmish mode, the artifact accompanies its unit and activates with it as if they formed the same squad.",
        "descripcion_escuadra": "Each Line or Elite unit in the faction may attach 1 miniature with the \"Artifact Support\" specialty, even if the squad is already at its maximum size. The artifact is added above the squad limit. In Skirmish mode, the artifact accompanies its unit and activates with it as if they formed the same squad."
      },
      {
        "id": "protocolos-de-combate",
        "habilidades_faccion3": "Combat Protocols",
        "coste": 5,
        "descripcion_escaramuza": "Once per turn, when a faction unit takes a Shoot action, apply -1 to the weapon's Precision value if at least one allied unit is within 6\" or less of the target. For example, Precision +4 counts as +3.",
        "descripcion_escuadra": "Once per turn, when a faction unit takes a Shoot action, apply -1 to the weapon's Precision value if at least one allied unit is within 6\" or less of the target. For example, Precision +4 counts as +3."
      }
    ]
  },
