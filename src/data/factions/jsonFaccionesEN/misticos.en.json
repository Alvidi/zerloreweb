{
  "faccion": {
    "nombre": "Mystics",
    "estilo_juego": "An agile and tactical faction, specialised in constant movement and in fighting at range and in melee from advantageous positions. Its units are fragile but fast, designed to strike and reposition before the enemy can respond. Ideal for players who enjoy tempo, mobility, and attacking from unexpected angles.",
    "seleccion_habilidades": "multiple",
    "habilidades_faccion": [
      {
        "id": "guerrilla-en-las-sombras",
        "habilidades_faccion1": "Guerrilla in the Shadows",
        "coste": 4,
        "descripcion_escaramuza": "This faction may deploy its Line units and Vehicles within 8\" of its command posts.",
        "descripcion_escuadra": "This faction may deploy its Line units and Vehicles within 8\" of its command posts."
      },
      {
        "id": "finta",
        "habilidades_faccion2": "Feint",
        "coste": 5,
        "descripcion_escaramuza": "When a Mystic unit is targeted by a ranged attack, it may immediately make a free return shot against the attacker. If that same unit is targeted by another ranged attack during the same turn, it cannot respond again.",
        "descripcion_escuadra": "When a Mystic unit is targeted by a ranged attack, it may immediately make a free return shot against the attacker. If that same unit is targeted by another ranged attack during the same turn, it cannot respond again."
      },
      {
        "id": "paso-fantasma",
        "habilidades_faccion3": "Ghost Step",
        "coste": 3,
        "descripcion_escaramuza": "When a Mystic unit is chosen as the target of a ranged attack, it may move up to 3\" before that attack is resolved. If after moving the attacker loses line of sight or the target is out of range, the attack is cancelled.",
        "descripcion_escuadra": "When a Mystic unit is chosen as the target of a ranged attack, it may move up to 3\" before that attack is resolved. If after moving the attacker loses line of sight or the target is out of range, the attack is cancelled."
      }
    ]
  },
