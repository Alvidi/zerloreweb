{
  "id": "caos",
  "faccion": {
    "nombre": "Chaos",
    "estilo_juego": "A faction built around waves and relentless pressure, designed to overwhelm the enemy with numbers and never stop advancing. Its Line units are the cheapest in the game: they die easily but return turn after turn from command posts. Melee and space control are its main weapons. Ideal for players who enjoy sustained pressure, gradual attrition, and controlled chaos.",
    "seleccion_habilidades": "multiple",
    "habilidades_faccion": [
      {
        "id": "oleada-eterna",
        "nombre": "Endless Wave",
        "coste": 8,
        "descripcion_escaramuza": "When a Line unit is destroyed, at the start of the next Initiative Phase it returns from any empty command post with all of its Wounds restored.",
        "descripcion_escuadra": "When a Line squad is destroyed, at the start of the next Initiative Phase it returns from any empty command post with all of its Wounds restored."
      },
      {
        "id": "instinto-de-enjambre",
        "nombre": "Horde Instinct",
        "coste": 4,
        "descripcion_escaramuza": "Units within 3\" of another allied unit may reroll failed melee attack dice.",
        "descripcion_escuadra": "Squads within 3\" of another allied squad may reroll failed melee attack dice."
      },
      {
        "id": "carga-salvaje",
        "nombre": "Savage Charge",
        "coste": 7,
        "descripcion_escaramuza": "When a unit from this faction makes a successful charge, it gains +1 Damage on its melee attacks for that activation.",
        "descripcion_escuadra": "When a squad from this faction makes a successful charge, it gains +1 Damage on its melee attacks for that activation."
      },
      {
        "id": "propagacion-de-veneno",
        "nombre": "Venom Spread",
        "coste": 6,
        "descripcion_escaramuza": "Enemy units that lose at least 1 Wound in melee against a Chaos unit must make a roll after the combat. On a 4+, that unit suffers 1 extra point of damage.",
        "descripcion_escuadra": "Enemy squads that lose at least 1 Wound in melee against a Chaos squad must make a roll after the combat. On a 4+, that squad suffers 1 extra point of damage."
      },
      {
        "id": "regeneracion",
        "nombre": "Regeneration",
        "coste": 6,
        "descripcion_escaramuza": "At the start of each Initiative Phase, one Chaos unit of your choice recovers 1 Wound, up to its maximum. It can only be used on units that were not destroyed that turn.",
        "descripcion_escuadra": "At the start of each Initiative Phase, one Chaos squad of your choice recovers D3 Wounds, up to its maximum. It can only be used on squads that were not destroyed that turn."
      }
    ]
  },
