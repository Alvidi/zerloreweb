{
  "id": "caos",
  "faccion": {
    "nombre": "Chaos",
    "estilo_juego": "A faction built around waves and relentless pressure, designed to overwhelm the enemy with numbers and never stop advancing. Its Line units are the cheapest in the game: they die easily but return turn after turn from command posts. Melee and space control are its main weapons. Ideal for players who enjoy sustained pressure, gradual attrition, and controlled chaos.",
    "seleccion_habilidades": "individual",
    "habilidades_faccion": [
      {
        "id": "endless-tide",
        "nombre": "Endless Tide",
        "descripcion_escaramuza": "At the end of each turn, every CHAOS Line unit destroyed during that turn returns to the battlefield with all its Wounds, deploying from any command post the player controls.",
        "descripcion_escuadra": "At the end of each turn, every CHAOS Line unit destroyed during that turn returns to the battlefield with all its Wounds, deploying from any command post the player controls.",
        "frase": "CHAOS does not end. The opponent must destroy you many times to be rid of you."
      },
      {
        "id": "the-prey",
        "nombre": "The Prey",
        "descripcion_escaramuza": "Once per turn, during the Initiative Phase, the player designates one visible enemy unit. All CHAOS melee attacks against that unit do not treat results of 1 and 2 as misses.",
        "descripcion_escuadra": "Once per turn, during the Initiative Phase, the player designates one visible enemy unit. All CHAOS melee attacks against that unit do not treat results of 1 and 2 as misses.",
        "frase": "When the pack chooses, the rest can only watch."
      },
      {
        "id": "blood-feast",
        "nombre": "Blood Feast",
        "descripcion_escaramuza": "Once per turn, during the Initiative Phase, the CHAOS player may sacrifice one CHAOS Line unit they control. That unit is removed from the battlefield without giving points to the opponent and without counting as destroyed for mission purposes. That unit transfers its remaining Wounds to another CHAOS unit; the receiving unit recovers Wounds up to its maximum and the rest are discarded.",
        "descripcion_escuadra": "Once per turn, during the Initiative Phase, the CHAOS player may sacrifice one CHAOS Line unit they control. That unit is removed from the battlefield without giving points to the opponent and without counting as destroyed for mission purposes. That unit transfers its remaining Wounds to another CHAOS unit; the receiving unit recovers Wounds up to its maximum and the rest are discarded.",
        "frase": "The weak feed the strong."
      }
    ]
  },
