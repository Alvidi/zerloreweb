{
  "id": "legado",
  "faccion": {
    "nombre": "Legacy",
    "estilo_juego": "A control-and-positioning faction built around quality over quantity. Its units are the toughest in the game, but it fields fewer of them. It uses portals to appear where the enemy least expects, revives its fallen with a chance roll, and strikes back even in death. The battlefield belongs to it if the player is patient. Ideal for strategic players who enjoy micromanagement, positioning, and making every unit count.",
    "seleccion_habilidades": "individual",
    "habilidades_faccion": [
      {
        "id": "last-breath",
        "nombre": "Last Breath",
        "descripcion_escaramuza": "When a LEGACY unit is destroyed, it makes one final ranged or melee attack whether it has actions or not.",
        "descripcion_escuadra": "When a LEGACY unit is destroyed, it makes one final ranged or melee attack whether it has actions or not.",
        "frase": "Nothing dies easily."
      },
      {
        "id": "the-void-calls",
        "nombre": "The Void Calls",
        "descripcion_escaramuza": "Once per turn, during the Initiative Phase and before any activation, LEGACY may swap the positions of any two allied units on the battlefield, as long as neither is locked in melee.",
        "descripcion_escuadra": "Once per turn, during the Initiative Phase and before any activation, LEGACY may swap the positions of any two allied units on the battlefield, as long as neither is locked in melee.",
        "frase": "The opponent cannot plan anything against you."
      },
      {
        "id": "echoes-of-the-past",
        "nombre": "Echoes of the Past",
        "descripcion_escaramuza": "When a LEGACY unit is destroyed, roll 1D6. On a 5 or 6, instead of removing it from the game, it returns to Reserve. To deploy it back onto the battlefield, you must spend Command Tokens according to its type: 1 token for Line, Elite, or Hero; 2 for Monster or Vehicle; 3 for Titan.",
        "descripcion_escuadra": "When a LEGACY unit is destroyed, roll 1D6. On a 5 or 6, instead of removing it from the game, it returns to Reserve. To deploy it back onto the battlefield, you must spend Command Tokens according to its type: 1 token for Line, Elite, or Hero; 2 for Monster or Vehicle; 3 for Titan.",
        "frase": "There is always a second chance."
      },
      {
        "id": "reserved-command",
        "nombre": "Reserved Command",
        "descripcion_escaramuza": "At the start of each Initiative Phase, this player gains 1 additional Command Token, added to those generated by command posts. The maximum number of accumulated Tokens remains 5.",
        "descripcion_escuadra": "At the start of each Initiative Phase, this player gains 1 additional Command Token, added to those generated by command posts. The maximum number of accumulated Tokens remains 5.",
        "frase": "The best battle is won with patience."
      }
    ]
  },
