{
  "faccion": {
    "nombre": "Reapers",
    "estilo_juego": "An implacable and slow faction, designed to advance without fear and without stopping. Its units never retreat and revive after being destroyed, wearing the enemy down. Ideal for players who enjoy inevitability and battlefield control through persistence.",
    "seleccion_habilidades": "multiple",
    "habilidades_faccion": [
      {
        "id": "reanimacion-mekanika",
        "habilidades_faccion1": "Mechanical Reanimation",
        "coste": 8,
        "descripcion_escaramuza": "If a Line or Elite unit is defeated, its body remains on the battlefield. At the start of the next Initiative Phase, roll 1D6: on a result of 1-4 the unit dies permanently and is removed; on a result of 5-6 the unit revives with half of its maximum Wounds.",
        "descripcion_escuadra": "If a Line or Elite unit is defeated, its body remains on the battlefield. At the start of the next Initiative Phase, roll 1D6: on a result of 1-4 the unit dies permanently and is removed; on a result of 5-6 the unit revives with half of its maximum Wounds."
      },
      {
        "id": "no-conocen-el-miedo",
        "habilidades_faccion2": "They Know No Fear",
        "coste": 4,
        "descripcion_escaramuza": "This faction cannot retreat and is not affected by any ability that would make it retreat.",
        "descripcion_escuadra": "This faction cannot retreat and is not affected by any ability that would make it retreat."
      },
      {
        "id": "protocolo-de-aniquilacion",
        "habilidades_faccion3": "Annihilation Protocol",
        "coste": 5,
        "descripcion_escaramuza": "Once per turn, when a unit destroys an enemy unit at range, it immediately gains +2 Wounds. This movement does not count as an action.",
        "descripcion_escuadra": "Once per turn, when a unit destroys an enemy unit at range, it immediately gains +2 Wounds. This movement does not count as an action."
      }
    ]
  },
