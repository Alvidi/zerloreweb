{
  "faccion": {
    "nombre": "Wild",
    "estilo_juego": "An aggressive and unpredictable faction, designed to overwhelm the enemy with numbers and speed. It sacrifices resilience in exchange for constant pressure and heavy melee power. Ideal for players who enjoy chaos and relentless offense.",
    "seleccion_habilidades": "multiple",
    "habilidades_faccion": [
      {
        "id": "furia-incontrolada",
        "habilidades_faccion1": "Uncontrolled Fury",
        "coste": 8,
        "descripcion_escaramuza": "One chosen Wild unit (line, elite, monster) that is going to charge gains +1 melee damage if the charge succeeds, once per turn.",
        "descripcion_escuadra": "One chosen Wild unit (line, elite, monster) that is going to charge gains +1 melee damage if the charge succeeds, once per turn."
      },
      {
        "id": "ley-del-mas-fuerte",
        "habilidades_faccion2": "Law of the strongest",
        "coste": 5,
        "descripcion_escaramuza": "Sacrifice the activation of one unit to activate again a unit that has already activated.",
        "descripcion_escuadra": "Sacrifice the activation of one unit to activate again a unit that has already activated. (In Grand Battle, this also applies to vehicles and monsters)"
      },
      {
        "id": "violencia-tribal",
        "habilidades_faccion3": "Tribal Violence",
        "coste": 3,
        "descripcion_escaramuza": "The first time per turn that a Wild unit eliminates an enemy unit in melee combat, it may immediately move 2\". This movement does not trigger checks and does not count as an action.",
        "descripcion_escuadra": "The first time per turn that a Wild unit eliminates an enemy unit in melee combat, it may immediately move 2\". This movement does not trigger checks and does not count as an action. (In Grand Battle, this also applies to monsters)"
      }
    ]
  },
