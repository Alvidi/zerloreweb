{
  "id": "orden",
  "faccion": {
    "nombre": "Order",
    "estilo_juego": "A disciplined and methodical faction focused on territorial control and sustained fire. Its units perform best when they hold position and coordinate tactically. It sacrifices mobility for power and precision. Ideal for players who enjoy planning each turn, establishing defensive lines, and punishing the enemy with balanced units.",
    "seleccion_habilidades": "individual",
    "habilidades_faccion": [
      {
        "id": "chain-of-command",
        "nombre": "Chain of Command",
        "descripcion_escaramuza": "Once per turn, when an ORDER unit activates, another ORDER unit within 6\" may activate immediately afterwards without waiting for the opponent's turn.",
        "descripcion_escuadra": "Once per turn, when an ORDER unit activates, another ORDER unit within 6\" may activate immediately afterwards without waiting for the opponent's turn.",
        "frase": "Order is the origin of justice"
      },
      {
        "id": "fortification",
        "nombre": "Fortification",
        "descripcion_escaramuza": "Command posts under your control count as being in cover.",
        "descripcion_escuadra": "Command posts under your control count as being in cover.",
        "frase": "Where we plant the banner, not one step back."
      },
      {
        "id": "doctrine",
        "nombre": "Doctrine",
        "descripcion_escaramuza": "Before the game begins, choose one enemy unit type (Line, Elite, Vehicle, Monster, Hero, or Titan). While your Order units attack units of that type, they ignore cover when shooting and ignore the Berserker and Resilient specialties.",
        "descripcion_escuadra": "Before the game begins, choose one enemy unit type (Line, Elite, Vehicle, Monster, Hero, or Titan). While your Order units attack units of that type, they ignore cover when shooting and ignore the Berserker and Resilient specialties.",
        "frase": "Know your enemy before raising your weapon."
      },
      {
        "id": "reserved-command",
        "nombre": "Reserved Command",
        "descripcion_escaramuza": "At the start of each Initiative Phase, this player gains 1 additional Reroll Token.",
        "descripcion_escuadra": "At the start of each Initiative Phase, this player gains 1 additional Reroll Token.",
        "frase": "The best battle is won with patience."
      }
    ]
  },
