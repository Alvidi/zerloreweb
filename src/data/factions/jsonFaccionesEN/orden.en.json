{
  "id": "orden",
  "faccion": {
    "nombre": "Order",
    "estilo_juego": "A disciplined and methodical faction focused on controlling territory and sustained fire. Its units perform best when they maintain position and tactical coordination. It sacrifices mobility in exchange for power and precision. Ideal for players who enjoy planning each turn, establishing defensive lines, and punishing the enemy with balanced units.",
    "seleccion_habilidades": "multiple",
    "habilidades_faccion": [
      {
        "id": "atrincheramiento",
        "nombre": "Entrenchment",
        "coste": 8,
        "descripcion_escaramuza": "A unit in cover gains +1 Shooting attack die during its activation until the end of that activation.",
        "descripcion_escuadra": "A squad in cover gains +1 Shooting attack die during its activation until the end of that activation."
      },
      {
        "id": "fuego-coordinado",
        "nombre": "Coordinated Fire",
        "coste": 5,
        "descripcion_escaramuza": "If an allied unit shoots the same target in the same turn, the second and later attackers apply -1 to their Precision value, improving the roll to hit for that turn.",
        "descripcion_escuadra": "If an allied squad or unit shoots the same target in the same turn, the second and later attackers apply -1 to their Precision value, improving the roll to hit for that turn."
      },
      {
        "id": "repliegue-tactico",
        "nombre": "Tactical Withdrawal",
        "coste": 4,
        "descripcion_escaramuza": "Once per turn, a unit may disengage from melee without making a retreat check.",
        "descripcion_escuadra": "Once per turn, a squad may disengage from melee without making a retreat check."
      },
      {
        "id": "artilleria-de-apoyo",
        "nombre": "Support Artillery",
        "coste": 7,
        "descripcion_escaramuza": "Once per turn, instead of activating a unit, you may bombard any point on the battlefield more than 6\" away from your own units. All units within 3\" of that point suffer 1 automatic hit with Damage 1 and no save.",
        "descripcion_escuadra": "Once per turn, instead of activating a squad or unit, you may bombard any point on the battlefield more than 6\" away from your own units. All squads or units within 3\" of that point suffer 1 automatic hit with Damage 1 and no save."
      },
      {
        "id": "formacion-de-asalto",
        "nombre": "Assault Formation",
        "coste": 5,
        "descripcion_escaramuza": "When a unit declares a charge, it may reroll one of the two dice from the 2D6 charge roll. The previous result is discarded.",
        "descripcion_escuadra": "When a squad declares a charge, it may reroll one of the two dice from the 2D6 charge roll. The previous result is discarded."
      },
      {
        "id": "contraofensiva",
        "nombre": "Counteroffensive",
        "coste": 4,
        "descripcion_escaramuza": "When an Order unit makes a counterattack in melee combat, it gains +1 melee die.",
        "descripcion_escuadra": "When an Order squad makes a counterattack in melee combat, it gains +1 melee die."
      }
    ]
  },
