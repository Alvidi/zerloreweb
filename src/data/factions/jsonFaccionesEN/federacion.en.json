{
  "faccion": {
    "nombre": "The Federation",
    "estilo_juego": "The Federation is a disciplined military force focused on steady fire, the use of cover, and tactical control of the battlefield. Their units work best when they stay organized, taking advantage of heavy weapons and supported fire, although they sacrifice mobility and close combat ability. They are ideal for players who prefer methodical strategies, defensive fire and winning by positioning.",
    "habilidades_faccion": [
      {
        "habilidades_faccion1": "Entrenchment",
        "descripcion": "A unit of this faction that has not taken any Move actions during its activation gains +1 Hit die on all of its Shooting attacks until the end of that activation."
      },
      {
        "habilidades_faccion2": "Raw Reinforcements",
        "descripcion": "Once per game, when a Line unit from this faction is completely eliminated, you may return it to the field to the deployment zone of your next Initiative phase."
      },
      {
        "habilidades_faccion3": "Fury of the Fallen",
        "descripcion": "When a unit falls from a squad, the entire squad gains +1 additional attack in the total attack. In Skirmish, units within 6\" gain an additional +1 attack, until end of turn."
      }
    ]
  },
