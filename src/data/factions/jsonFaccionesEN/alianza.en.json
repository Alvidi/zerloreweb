      {
        "id": "potencia-blindada",
        "habilidades_faccion1": "Armored power",
        "descripcion": "Vehicles can carry two ranged weapons equipped."
      },
      {
        "id": "objetivo-en-la-mira",
        "habilidades_faccion2": "Target in sight",
        "descripcion": "During the Initiative Phase, this faction may mark one visible enemy unit. All Alliance units/squads may reroll failed Hit rolls against that target during this turn."
      },
      {
        "id": "resistencia-marcial",
        "habilidades_faccion3": "Martial resistance",
        "descripcion": "When an allied unit/squad is at a command point, enemy attackers suffer +1 to the Hit value needed on their ranged attacks against that unit."
